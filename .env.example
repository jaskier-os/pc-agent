# pc-agent configuration. Copy this file to .env and fill in the values.
# Lines marked REQUIRED have no working default.

# --- Orchestrator / Communicator connectivity ---
# WebSocket URL of the orchestrator this agent registers with.
# Plain ws:// works out of the box; use wss:// only if you have TLS (see TLS section).
ORCHESTRATOR_URL=ws://localhost:10001
# HTTP(S) base URL of the communicator / LLM gateway used by the explore tool.
COMMUNICATOR_URL=http://localhost:10000
# REQUIRED. Shared API key the orchestrator/communicator expect from this agent.
API_KEY=

# --- Model selection ---
# Default model alias passed to code tasks (e.g. sonnet, opus, haiku).
MODEL=sonnet
# Optional model override for the read-only explore tool. Empty = use MODEL.
EXPLORE_MODEL=

# --- Local HTTP server ---
# Port for the agent's health endpoint and the /api/v1/tg-upload route. 0 disables.
HEALTH_PORT=10004

# --- Telegram (test-recording bounce / notifications) ---
# REQUIRED. Telegram API credentials from https://my.telegram.org/apps
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
# Telegram StringSession. Leave empty on first run to log in via QR code;
# the agent will persist the generated session back into this .env file.
TELEGRAM_SESSION=

# --- Remote code sessions (remote-session-cli) ---
# Comma-separated list of directories the agent may open remote code sessions in.
# Defaults to the current user's home directory if unset.
REMOTE_SESSION_DIRS=
# Absolute path to the remote-session CLI binary (jaskier-os/remote-session-cli).
# If empty, `remote-session` is looked up on PATH -- independent of any `claude` command.
REMOTE_SESSION_BIN=

# --- Code task limits ---
CODE_TASK_MAX_TURNS=50
# One of: default, acceptEdits, bypassPermissions, plan
CODE_TASK_PERMISSION_MODE=acceptEdits

# --- Command execution guardrails (optional; sane defaults built in) ---
# ALLOWED_COMMANDS=ls,cat,grep,echo,node,npm,python3
# BLOCKED_PATTERNS=rm -rf /,mkfs,dd if=,shutdown,reboot
# MAX_OUTPUT_LENGTH=10000
# COMMAND_TIMEOUT_MS=30000

# --- Optional TLS (see README "Optional TLS / secure connectivity") ---
# Absolute path to a CA certificate. Only used when ORCHESTRATOR_URL is wss://.
# If unset or missing, the agent connects without a custom CA (plain by default).
# NODE_EXTRA_CA_CERTS=

# --- Optional outbound proxy ---
# If you route outbound traffic through an HTTP/SOCKS proxy, set one of these.
# When unset, the agent auto-detects GNOME proxy settings or a local v2ray port.
# PROXY_URL=http://127.0.0.1:10808
